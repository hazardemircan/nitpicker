# Copy this file to .env and fill in your values for local testing.
# .env is gitignored; never commit real keys.
#
# The local-test scripts (scripts/local-test.sh / .ps1) load this file.
# The reviewer binary itself only reads real environment variables, so .env is
# never consulted in CI; Azure DevOps provides the variables there.

# --- OpenAI ---
# Your OpenAI API key. Required unless MOCK_AI=1.
OPENAI_API_KEY=sk-your-key-here

# Optional: override the API endpoint (e.g. for an Azure OpenAI deployment).
# Defaults to https://api.openai.com/v1
# OPENAI_BASE_URL=

# --- Local testing flags ---
# MOCK_AI=1 returns a fake finding instead of calling OpenAI (no key needed).
MOCK_AI=0

# DRY_RUN=1 prints comments to stdout instead of posting them to Azure DevOps.
DRY_RUN=1

# In Azure DevOps these are provided automatically by the pipeline and do NOT
# belong in a .env file: SYSTEM_TEAMFOUNDATIONCOLLECTIONURI, SYSTEM_TEAMPROJECT,
# BUILD_REPOSITORY_ID, SYSTEM_ACCESSTOKEN, BUILD_REPOSITORY_LOCALPATH,
# SYSTEM_PULLREQUEST_PULLREQUESTID, SYSTEM_PULLREQUEST_TARGETBRANCHNAME.
